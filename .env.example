# Path to the TorchScript RAVE model (local fallback if HF_REPO_ID is not set)
MODEL_PATH=organ.ts

# Directory where generated audio files are stored
RESULTS_DIR=results

# CORS: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Persistent cache dir for downloaded models (use /data/models on HF Spaces)
MODEL_CACHE_DIR=/data/models

# Hugging Face Hub repo containing the model file (leave empty to use local MODEL_PATH)
HF_REPO_ID=Intelligent-Instruments-Lab/rave-models

# Available models: organ_archive, organ_bach, guitar_iil, voice_vocalset,
# birds_motherbird, marinemammals_pondbrain — see full list at
# https://huggingface.co/Intelligent-Instruments-Lab/rave-models
HF_FILENAME=organ_archive_b2048_r48000_z16.ts

# Frontend env var (set in frontend/.env)
# VITE_API_BASE=http://127.0.0.1:8000
